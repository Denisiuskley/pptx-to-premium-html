D-8244-4546-03F0D4ABB4F3}"/></a:ext></a:extLst></p:cNvPr><p:cNvPicPr><a:picLocks noChangeAspect="1"/></p:cNvPicPr><p:nvPr/></p:nvPicPr><p:blipFill><a:blip r:embed="rId2"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:stretch><a:fillRect/></a:stretch></p:blipFill><p:spPr><a:xfrm><a:off x="9138342" y="1516683"/><a:ext cx="2828371" cy="4586349"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr></p:pic><p:sp><p:nvSpPr><p:cNvPr id="9" name="TextBox 8"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{6FA66784-0E00-D375-EFB2-5E8E363692FD}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="178904" y="1403392"/><a:ext cx="5917096" cy="5355312"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="square"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="just"/><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Фильтрация исходных данных</a:t></a:r></a:p><a:p><a:pPr algn="just"/><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Для обеспечения высокого качества данных и репрезентативности выборки был применен ряд фильтров:</a:t></a:r></a:p><a:p><a:pPr marL="285750" indent="-285750" algn="just"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Исключены горизонтальные скважины.</a:t></a:r></a:p><a:p><a:pPr marL="285750" indent="-285750" algn="just"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Удалены парные скважины, проходящие через одни и те же ячейки модели, во избежание дублирования информации.</a:t></a:r></a:p><a:p><a:pPr marL="285750" indent="-285750" algn="just"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Исключены 5 скважин с неудовлетворительными результатами прогнозирования на этапе предварительного анализа.</a:t></a:r></a:p><a:p><a:pPr algn="just"/><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>В результате фильтрации итоговая выборка для обучения и валидации моделей составила 44 скважины и 26 000 элементов.</a:t></a:r></a:p><a:p><a:pPr algn="just"/><a:endParaRPr lang="ru-RU" dirty="0"/></a:p><a:p><a:pPr algn="just"/><a:r><a:rPr lang="ru-RU" dirty="0"/><a:t>Для исключения мультиколлинеарности в обучающих данных находились попарные разности сейсмических кубов.</a:t></a:r></a:p><a:p><a:pPr algn="just"/><a:endParaRPr lang="ru-RU" dirty="0"/></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="871030594"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>